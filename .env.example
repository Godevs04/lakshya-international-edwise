# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nandhini-crm?retryWrites=true&w=majority

# Server (must match AUTH_URL port)
PORT=4000

# Auth.js — AUTH_URL must match your dev server URL
AUTH_SECRET=your-auth-secret-min-32-chars-long
AUTH_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=your-auth-secret-min-32-chars-long

# Seed Admin (run once: npm run seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin

# Company defaults (used until Settings are saved in DB)
APP_COMPANY_NAME=Nandhini Consultancy
APP_COMPANY_EMAIL=hello@example.com
APP_COMPANY_PHONE=
APP_COMPANY_ADDRESS=
APP_COMPANY_LOGO=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# SMTP — Gmail (Google App Password required if 2FA is on)
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM="Nandhini Consultancy <your@gmail.com>"

# Encryption (32-byte hex for AES-256)
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional theme defaults
APP_THEME_PRIMARY=oklch(0.488 0.243 264.376)
APP_THEME_ACCENT=oklch(0.556 0 0)
APP_SESSION_EXPIRY_HOURS=24

# Optional email banner (full-width header image URL, e.g. Cloudinary)
# APP_EMAIL_BANNER_URL=https://res.cloudinary.com/your-cloud/image/upload/v1/email-banner.jpg

# Optional error tracking (Sentry) — confidential, keep in .env.local only
# SENTRY_DSN=https://publicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://publicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token_for_source_map_uploads
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1

# Optional Redis for shared rate limiting across instances (falls back to in-memory if unset)
# REDIS_URL=redis://localhost:6379

# Registration — keep false in production to disable public /register
ALLOW_PUBLIC_REGISTRATION=false
